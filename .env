# Chromeの実行ファイルのパス
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# Chromeのデバッグ用ポート番号
CHROME_PORT=9222
# Chromeのプロファイル保存先
CHROME_USER_DATA_DIR=C:\Users\takem\Workspace\Programming\ContentGenerator\config\chrome_profile
# GeminiのURL
GEMINI_URL=https://gemini.google.com/app?hl=ja
# Geminiの入力用要素
GEMINI_INPUT_SELECTER=div[contenteditable="true"]
# Geminiの出力用要素
GEMINI_IMG_SELECTER=model-response img
GEMINI_TXT_SELECTER=model-response
# 参照用URLを記載するファイルのパス
TARGET_URLS_PATH=inputs/urls.txt
# プロンプトの保存先
PROMPT_DIR=inputs/prompts/
# 生成データの保存先
RESULT_DIR=results/